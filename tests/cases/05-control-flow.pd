int x = 10;
int y = 5;

if (x > y) {
    print "x is greater than y";
} else {
    print "x is not greater than y";
}

x = 5;
y = 10;

if (x > y) {
    print "x is greater than y";
} else {
    print "x is not greater than y";
}

x = 10;

if (x == y) {
    print "x is equal to y";
} else {
    print "x is not equal to y";
}

x = 5;

if (x == y) {
    print "x is equal to y";
} else {
    print "x is not equal to y";
}