
void test() {
    print "Hello world!";
}

struct Test {
    void* v;
    int* i;
    char* c;
    double* d;
    bool* b;
}

inst Test t;

t.v = &test;
t.i = &5;
t.c = &'a';
t.d = &3.14;
t.b = &true;

print t.v;
print t.i;
print t.c;
print t.d;
print t.b;

print *t.v;
(*t.v)();
print *t.i;
print *t.c;
print *t.d;
print *t.b;